{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "ES2021.WeakRef"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/db/*": [
        "src/db/*"
      ],
      "@/database/*": [
        "database/*"
      ]
    },
    "outDir": "./dist/",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/**/*",
    ".next/types/**/*.ts",
    "src/phosphor-icons.d.ts",
    "src/types/**/*.d.ts",
    "types/**/*.d.ts",
    "database/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts/**/*.js"
  ]
}
